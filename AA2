// AA2.go
package main

import (
	"fmt"
	"time"
)

// --- ESTRUCTURAS Y ENCAPSULACIÓN ---
type Producto struct {
	Nombre   string
	Material string
	Precio   float64
}

// --- INTERFACES (Simulación de Notificaciones) ---
type Notificador interface {
	Enviar(mensaje string)
}

type AlertaVenta struct{}

func (a AlertaVenta) Enviar(msg string) {
	fmt.Printf("\n[NOTIFICACIÓN] %s\n", msg)
}

// --- CONCURRENCIA (Proceso en segundo plano) ---
func procesoImpresion(nombre string) {
	// Simulamos que la impresora tarda 5 segundos
	time.Sleep(5 * time.Second)
	fmt.Printf("\n\n[🖨️  AVISO]: La pieza '%s' ha terminado de imprimirse.\n", nombre)
	fmt.Print("Seleccione una opción: ") // Para no perder el prompt del menú
}

func main() {
	//  MAPS Y SLICES ---
	inventario := make(map[string]int) // Material -> Gramos
	inventario["PLA"] = 20000
	inventario["RESINA"] = 15000

	var catalogo []Producto
	alerta := AlertaVenta{}

	for {
		fmt.Println("\n--- PANEL DE CONTROL FOLAN 3D ---")
		fmt.Println("1. Registrar nuevo Producto")
		fmt.Println("2. Ver Catálogo y Stock")
		fmt.Println("3. Mandar a Imprimir (Concurrente)")
		fmt.Println("4. Salir")
		fmt.Print("Seleccione una opción: ")

		var opcion int
		fmt.Scan(&opcion)

		switch opcion {
		case 1:
			var n, m string
			var p float64
			fmt.Print("Nombre de la pieza: ")
			fmt.Scan(&n)
			fmt.Print("Material (PLA/RESINA): ")
			fmt.Scan(&m)
			fmt.Print("Precio de venta: ")
			fmt.Scan(&p)

			nuevo := Producto{Nombre: n, Material: m, Precio: p}
			catalogo = append(catalogo, nuevo)
			alerta.Enviar("Producto registrado exitosamente.")

		case 2:
			fmt.Println("\n--- CATÁLOGO ACTUAL ---")
			for i, prod := range catalogo {
				fmt.Printf("%d. %s [%s] - $%.2f\n", i+1, prod.Nombre, prod.Material, prod.Precio)
			}
			fmt.Printf("Stock PLA: %dg | Stock RESINA: %dg\n", inventario["PLA"], inventario["RESINA"])

		case 3:
			if len(catalogo) == 0 {
				fmt.Println("No hay productos en el catálogo para imprimir.")
				continue
			}
			var indice int
			fmt.Print("Ingrese el número del producto a imprimir: ")
			fmt.Scan(&indice)

			if indice > 0 && indice <= len(catalogo) {
				seleccionado := catalogo[indice-1]
				// LANZAMOS GOROUTINE (Unidad 1)
				fmt.Println("[!] Mandando a la cola de impresión... puedes seguir usando el programa.")
				go procesoImpresion(seleccionado.Nombre)

				// Descontamos del mapa (Unidad 2)
				inventario[seleccionado.Material] -= 50
			}

		case 4:
			fmt.Println("Cerrando sistema de Folan 3D...")
			return

		default:
			fmt.Println("Opción no válida.")
		}
	}
}
